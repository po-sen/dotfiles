#!/usr/bin/env bash

set -euo pipefail

script_dir="$(
    cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P
)"

CODEX_BIN="${CODEX_NOTIFY_CODEX_BIN:-$(command -v codex)}"
CODEX_NOTIFY_APPROVAL_WATCHER="${CODEX_NOTIFY_APPROVAL_WATCHER:-1}"
CODEX_NOTIFY_SOUND="${CODEX_NOTIFY_SOUND:-/System/Library/Sounds/Funk.aiff}"
CODEX_APPROVAL_SOUND="${CODEX_APPROVAL_SOUND:-/System/Library/Sounds/Hero.aiff}"
CODEX_NOTIFY_POPUP="${CODEX_NOTIFY_POPUP:-1}"
CODEX_NOTIFY_LOG_FILE="${CODEX_NOTIFY_LOG_FILE:-}"
CODEX_NOTIFY_TITLE="${CODEX_NOTIFY_TITLE:-Codex}"
CODEX_NOTIFY_TERMINAL_NOTIFIER="${CODEX_NOTIFY_TERMINAL_NOTIFIER:-}"
CODEX_NOTIFY_CLICK_HANDLER="${CODEX_NOTIFY_CLICK_HANDLER:-$script_dir/codex-focus-ghostty}"
CODEX_NOTIFY_GHOSTTY_BUNDLE_ID="${CODEX_NOTIFY_GHOSTTY_BUNDLE_ID:-com.mitchellh.ghostty}"
CODEX_NOTIFY_MESSAGE_MAX_CHARS="${CODEX_NOTIFY_MESSAGE_MAX_CHARS:-90}"

resolve_terminal_notifier() {
    local candidate=""

    for candidate in \
        "$CODEX_NOTIFY_TERMINAL_NOTIFIER" \
        /opt/homebrew/bin/terminal-notifier \
        /usr/local/bin/terminal-notifier \
        "$(command -v terminal-notifier 2>/dev/null || true)"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

escape_osascript_string() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

extract_json_field() {
    local key="$1"
    local payload="$2"

    printf '%s\n' "$payload" | sed -n "s/.*\"$key\":\"\\([^\"]*\\)\".*/\\1/p"
}

json_get_string() {
    local payload="$1"
    local key="$2"

    python3 - "$payload" "$key" <<'PY'
import json
import sys

payload = sys.argv[1]
key = sys.argv[2]

try:
    value = json.loads(payload).get(key, "")
except Exception:
    value = ""

if isinstance(value, str):
    sys.stdout.write(value)
PY
}

approval_detail_from_event() {
    local payload="$1"

    python3 - "$payload" <<'PY'
import json
import sys

payload = sys.argv[1]

def pick_value(obj):
    if not isinstance(obj, dict):
        return ""
    for key in ("justification", "reason"):
        value = obj.get(key)
        if isinstance(value, str) and value.strip():
            return value
    value = obj.get("cmd")
    if isinstance(value, str) and value.strip():
        return value
    command = obj.get("command")
    if isinstance(command, list) and command:
        return " ".join(str(part) for part in command)
    if isinstance(command, str) and command.strip():
        return command
    return ""

detail = ""

try:
    outer = json.loads(payload)
except Exception:
    outer = None

if isinstance(outer, dict):
    detail = pick_value(outer.get("payload"))
    if not detail:
        arguments = outer.get("payload", {}).get("arguments")
        if isinstance(arguments, str):
            try:
                detail = pick_value(json.loads(arguments))
            except Exception:
                detail = ""

sys.stdout.write(detail)
PY
}

approval_detail_from_arg() {
    local detail="${1:-}"

    case "$detail" in
        \{*)
            approval_detail_from_event "$detail"
            ;;
        *)
            printf '%s' "$detail"
            ;;
    esac
}

project_name_from_path() {
    local project_path="$1"

    if [ -z "$project_path" ] || [ "$project_path" = "/" ] || [ "$project_path" = "." ]; then
        return 0
    fi

    basename "$project_path"
}

project_path_from_payload() {
    local payload="$1"
    local project_path=""

    project_path="$(extract_json_field "cwd" "$payload")"
    if [ -z "$project_path" ]; then
        project_path="$(extract_json_field "working_directory" "$payload")"
    fi

    printf '%s\n' "$project_path"
}

log_notification() {
    local kind="$1"
    local message="$2"
    local log_message=""

    log_message="$(printf '%s' "$message" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"

    if [ -n "$CODEX_NOTIFY_LOG_FILE" ]; then
        printf '%s\t%s\t%s\n' "$kind" "$(date '+%Y-%m-%d %H:%M:%S')" "$log_message" >> "$CODEX_NOTIFY_LOG_FILE"
    fi
}

play_sound() {
    local sound_path="$1"

    if [ -x /usr/bin/afplay ] && [ -r "$sound_path" ]; then
        /usr/bin/afplay "$sound_path" >/dev/null 2>&1 &
    fi
}

shell_single_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

build_click_command() {
    local project_path="$1"
    local helper="${CODEX_NOTIFY_CLICK_HANDLER:-}"
    local quoted_helper=""

    if [ -z "$helper" ] || [ ! -x "$helper" ]; then
        return 1
    fi

    quoted_helper="$(shell_single_quote "$helper")"
    if [ -n "$project_path" ]; then
        printf '%s %s\n' "$quoted_helper" "$(shell_single_quote "$project_path")"
        return 0
    fi

    printf '%s\n' "$quoted_helper"
}

show_popup_with_osascript() {
    local title="$1"
    local subtitle="$2"
    local message="$3"
    local escaped_title=""
    local escaped_subtitle=""
    local escaped_message=""

    if [ ! -x /usr/bin/osascript ]; then
        return 0
    fi

    escaped_title="$(escape_osascript_string "$title")"
    escaped_subtitle="$(escape_osascript_string "$subtitle")"
    escaped_message="$(escape_osascript_string "$message")"
    /usr/bin/osascript -e "display notification \"$escaped_message\" with title \"$escaped_title\" subtitle \"$escaped_subtitle\"" >/dev/null 2>&1 &
}

show_popup() {
    local title="$1"
    local subtitle="$2"
    local message="$3"
    local project_path="${4:-}"
    local click_command=""
    local terminal_notifier=""
    local -a notifier_args=()

    if [ "$CODEX_NOTIFY_POPUP" != "1" ]; then
        return 0
    fi

    click_command="$(build_click_command "$project_path" || true)"
    terminal_notifier="$(resolve_terminal_notifier || true)"
    if [ -n "$terminal_notifier" ]; then
        notifier_args=(
            -title "$title"
            -subtitle "$subtitle"
            -message "$message"
            -activate "$CODEX_NOTIFY_GHOSTTY_BUNDLE_ID"
        )
        if [ -n "$click_command" ]; then
            notifier_args+=(-execute "$click_command")
        fi
        "$terminal_notifier" "${notifier_args[@]}" >/dev/null 2>&1 &
        return 0
    fi

    show_popup_with_osascript "$title" "$subtitle" "$message"
}

normalize_notification_text() {
    local text="$1"

    python3 - "$text" <<'PY'
import re
import sys

text = sys.argv[1]

text = text.replace("\r", " ").replace("\n", " ")
text = re.sub(r"```.*?```", " ", text, flags=re.S)
text = re.sub(r"`([^`]*)`", r"\1", text)
text = re.sub(r"!\[([^\]]*)\]\([^)]+\)", r"\1", text)
text = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", text)
text = re.sub(r"^\s{0,3}#{1,6}\s*", "", text)
text = re.sub(r"[*_~]+", "", text)
text = re.sub(r"^\s{0,3}>\s*", "", text)
text = re.sub(r"\s+", " ", text).strip()

sys.stdout.write(text)
PY
}

first_line_notification_text() {
    local text="$1"

    python3 - "$text" <<'PY'
import sys

text = sys.argv[1]
text = text.replace("\r\n", "\n").replace("\r", "\n")
sys.stdout.write(text.split("\n", 1)[0])
PY
}

truncate_notification_text() {
    local text="$1"
    local max_chars="${2:-$CODEX_NOTIFY_MESSAGE_MAX_CHARS}"

    python3 - "$text" "$max_chars" <<'PY'
import sys

text = sys.argv[1].strip()
try:
    max_chars = int(sys.argv[2])
except Exception:
    max_chars = 90

if max_chars < 4 or len(text) <= max_chars:
    sys.stdout.write(text)
else:
    cut = text[: max_chars - 3]
    space = cut.rfind(" ")
    if space >= max(12, (max_chars - 3) // 2):
        cut = cut[:space]
    sys.stdout.write(cut.rstrip() + "...")
PY
}

status_line_for_project() {
    local project_path="$1"
    local status_suffix="$2"
    local project_name=""

    project_name="$(project_name_from_path "$project_path")"
    if [ -n "$project_name" ]; then
        printf '%s %s\n' "$project_name" "$status_suffix"
        return 0
    fi

    printf '%s\n' "$status_suffix"
}

notify_with_project() {
    local kind="$1"
    local sound_path="$2"
    local status_suffix="$3"
    local fallback_detail="$4"
    local project_path="${5:-}"
    local detail="${6:-}"
    local subtitle=""
    local message=""
    local log_message=""

    subtitle="$(status_line_for_project "$project_path" "$status_suffix")"
    case "$kind" in
        task_complete)
            detail="$(first_line_notification_text "$detail")"
            detail="$(normalize_notification_text "$detail")"
            if [ -z "$detail" ]; then
                detail="$fallback_detail"
            fi
            message="$(truncate_notification_text "$detail")"
            ;;
        *)
            detail="$(normalize_notification_text "$detail")"
            if [ -z "$detail" ]; then
                detail="$fallback_detail"
            fi
            message="$(truncate_notification_text "$detail")"
            ;;
    esac
    log_message="$subtitle"
    if [ -n "$message" ]; then
        log_message="$log_message | $message"
    fi

    log_notification "$kind" "$log_message"
    play_sound "$sound_path"
    show_popup "$CODEX_NOTIFY_TITLE" "$subtitle" "$message" "$project_path"
}

notify_task_complete() {
    notify_with_project "task_complete" "$CODEX_NOTIFY_SOUND" "finished" "Open Codex for details." "${1:-}" "${2:-}"
}

notify_approval_required() {
    notify_with_project "approval_required" "$CODEX_APPROVAL_SOUND" "needs approval" "Open Codex to review." "${1:-}" "${2:-}"
}

handle_native_payload() {
    local payload="${1:-}"
    local project_path=""
    local detail=""

    project_path="$(project_path_from_payload "$payload")"
    if [ -z "$project_path" ]; then
        project_path="${PWD:-}"
    fi

    case "$payload" in
        *'"type":"agent-turn-complete"'*)
            detail="$(json_get_string "$payload" "last-assistant-message")"
            notify_task_complete "$project_path" "$detail"
            ;;
    esac
}

handle_script_mode() {
    case "${1:-}" in
        --native-handler)
            shift
            handle_native_payload "${1:-}"
            return 0
            ;;
        --approval-notify)
            shift
            notify_approval_required "${1:-${PWD:-}}" "$(approval_detail_from_arg "${2:-}")"
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

cleanup() {
    if [ -n "${watcher_pid:-}" ]; then
        kill "$watcher_pid" >/dev/null 2>&1 || true
        wait "$watcher_pid" 2>/dev/null || true
    fi
    if [ -n "${child_pid_file:-}" ] && [ -e "$child_pid_file" ]; then
        rm -f "$child_pid_file"
    fi
    if [ -n "${marker_file:-}" ] && [ -e "$marker_file" ]; then
        rm -f "$marker_file"
    fi
}

is_interactive_codex() {
    if [ "$#" -eq 0 ]; then
        return 0
    fi

    case "$1" in
        -*|resume|fork)
            return 0
            ;;
        exec|review|login|logout|mcp|marketplace|mcp-server|app-server|app|completion|sandbox|debug|apply|cloud|exec-server|features|help)
            return 1
            ;;
        *)
            return 0
            ;;
    esac
}

parse_requested_cwd() {
    local requested_cwd="${PWD:-}"

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -C|--cd)
                shift
                if [ "$#" -gt 0 ]; then
                    requested_cwd="$1"
                    shift
                fi
                ;;
            --cd=*)
                requested_cwd="${1#--cd=}"
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    printf '%s\n' "$requested_cwd"
}

new_run_marker() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr '[:upper:]' '[:lower:]'
    else
        printf '%s\n' "codex-notify-$$-$RANDOM-$(date '+%s')"
    fi
}

main() {
    local notify_config=""
    local requested_cwd=""
    local run_marker=""
    local approval_watcher=""
    local terminal_filter=""
    local child_pid_file=""
    local -a codex_args=()

    if handle_script_mode "$@"; then
        return 0
    fi

    if ! is_interactive_codex "$@"; then
        exec "$CODEX_BIN" "$@"
    fi

    approval_watcher="$script_dir/codex-watch-approval"
    terminal_filter="$script_dir/codex-terminal-filter"
    requested_cwd="$(parse_requested_cwd "$@")"
    marker_file="$(mktemp)"
    child_pid_file="$(mktemp)"
    run_marker="$(new_run_marker)"
    watcher_pid=""
    trap cleanup EXIT

    if [ "$CODEX_NOTIFY_APPROVAL_WATCHER" = "1" ]; then
        "$approval_watcher" "$marker_file" "$run_marker" "$requested_cwd" "$child_pid_file" &
        watcher_pid=$!
    fi

    printf -v notify_config 'notify=["%s","--native-handler"]' "$script_dir/codex-notify"
    codex_args=(-c "$notify_config" -c 'tui.notifications=false' "$@")
    if [ -x "$terminal_filter" ]; then
        CODEX_NOTIFY_CHILD_PID_FILE="$child_pid_file" CODEX_NOTIFY_RUN_MARKER="$run_marker" "$terminal_filter" "$CODEX_BIN" "${codex_args[@]}"
        return
    fi
    CODEX_NOTIFY_RUN_MARKER="$run_marker" "$CODEX_BIN" "${codex_args[@]}"
}

main "$@"
