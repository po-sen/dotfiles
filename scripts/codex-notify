#!/usr/bin/env bash

set -euo pipefail

payload="${1:-}"
notify_sound="${CODEX_NOTIFY_SOUND:-/System/Library/Sounds/Funk.aiff}"
notify_popup="${CODEX_NOTIFY_POPUP:-1}"

case "$payload" in
    *'"type":"agent-turn-complete"'*)
        ;;
    *)
        exit 0
        ;;
esac

if [ -r "$notify_sound" ] && [ -x /usr/bin/afplay ]; then
    /usr/bin/afplay "$notify_sound" >/dev/null 2>&1 &
fi

if [ "$notify_popup" = "1" ] && [ -x /usr/bin/osascript ]; then
    /usr/bin/osascript -e 'display notification "Turn complete" with title "Codex"' >/dev/null 2>&1 &
fi
