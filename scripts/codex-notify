#!/usr/bin/env bash

set -euo pipefail

CODEX_BIN_DEFAULT="$(command -v codex)"
CODEX_BIN="${CODEX_NOTIFY_CODEX_BIN:-$CODEX_BIN_DEFAULT}"
CODEX_SESSIONS_DIR="${CODEX_NOTIFY_SESSIONS_DIR:-$HOME/.codex/sessions}"
CODEX_NOTIFY_SOUND="${CODEX_NOTIFY_SOUND:-/System/Library/Sounds/Glass.aiff}"
CODEX_APPROVAL_SOUND="${CODEX_APPROVAL_SOUND:-/System/Library/Sounds/Hero.aiff}"
CODEX_NOTIFY_POPUP="${CODEX_NOTIFY_POPUP:-1}"
CODEX_NOTIFY_LOG_FILE="${CODEX_NOTIFY_LOG_FILE:-}"

is_interactive_codex() {
    if [ "$#" -eq 0 ]; then
        return 0
    fi

    case "$1" in
        -*)
            return 0
            ;;
        resume|fork)
            return 0
            ;;
        exec|review|login|logout|mcp|marketplace|mcp-server|app-server|app|completion|sandbox|debug|apply|cloud|exec-server|features|help)
            return 1
            ;;
        *)
            return 0
            ;;
    esac
}

pick_session_file() {
    local marker_file="$1"
    local newest=""
    local candidate=""

    while IFS= read -r candidate; do
        [ -n "$candidate" ] || continue
        if [ -z "$newest" ] || [ "$candidate" -nt "$newest" ]; then
            newest="$candidate"
        fi
    done < <(find "$CODEX_SESSIONS_DIR" -type f -name '*.jsonl' -newer "$marker_file" 2>/dev/null)

    printf '%s\n' "$newest"
}

play_sound() {
    local sound_path="$1"
    if [ -x /usr/bin/afplay ] && [ -r "$sound_path" ]; then
        /usr/bin/afplay "$sound_path" >/dev/null 2>&1 &
    fi
}

show_popup() {
    local title="$1"
    local message="$2"
    if [ "$CODEX_NOTIFY_POPUP" = "1" ] && [ -x /usr/bin/osascript ]; then
        /usr/bin/osascript -e "display notification \"$message\" with title \"$title\"" >/dev/null 2>&1 &
    fi
}

notify_task_complete() {
    if [ -n "$CODEX_NOTIFY_LOG_FILE" ]; then
        printf 'task_complete\t%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" >> "$CODEX_NOTIFY_LOG_FILE"
    fi

    play_sound "$CODEX_NOTIFY_SOUND"
    show_popup "Codex" "Turn complete"
}

notify_approval_required() {
    if [ -n "$CODEX_NOTIFY_LOG_FILE" ]; then
        printf 'approval_required\t%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" >> "$CODEX_NOTIFY_LOG_FILE"
    fi

    play_sound "$CODEX_APPROVAL_SOUND"
    show_popup "Codex" "Approval required"
}

monitor_codex_session() {
    local marker_file="$1"
    local session_file=""
    local line=""

    while :; do
        session_file="$(pick_session_file "$marker_file")"
        if [ -n "$session_file" ]; then
            break
        fi
        sleep 1
    done

    tail -n0 -F "$session_file" 2>/dev/null | while IFS= read -r line; do
        case "$line" in
            *'"type":"task_complete"'*)
                notify_task_complete
                ;;
        esac

        case "$line" in
            *'"type":"function_call"'*'sandbox_permissions'*'require_escalated'*)
                notify_approval_required
                ;;
        esac
    done
}

cleanup() {
    if [ -n "${watcher_pid:-}" ]; then
        kill "$watcher_pid" >/dev/null 2>&1 || true
    fi
    if [ -n "${marker_file:-}" ] && [ -e "$marker_file" ]; then
        rm -f "$marker_file"
    fi
}

main() {
    if ! is_interactive_codex "$@"; then
        exec "$CODEX_BIN" "$@"
    fi

    marker_file="$(mktemp)"
    watcher_pid=""
    trap cleanup EXIT

    monitor_codex_session "$marker_file" &
    watcher_pid=$!

    "$CODEX_BIN" "$@"
}

main "$@"
