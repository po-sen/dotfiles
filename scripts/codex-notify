#!/usr/bin/env bash

set -euo pipefail

script_dir="$(
    cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P
)"

if [ -z "${HOME:-}" ]; then
    HOME="$(
        cd ~ >/dev/null 2>&1 && pwd -P
    )"
    export HOME
fi

CODEX_BIN="${CODEX_NOTIFY_CODEX_BIN:-}"
CODEX_NOTIFY_SOUND="${CODEX_NOTIFY_SOUND:-/System/Library/Sounds/Funk.aiff}"
CODEX_NOTIFY_APPROVAL_SOUND="${CODEX_NOTIFY_APPROVAL_SOUND:-/System/Library/Sounds/Sosumi.aiff}"
CODEX_NOTIFY_POPUP="${CODEX_NOTIFY_POPUP:-1}"
CODEX_NOTIFY_LOG_FILE="${CODEX_NOTIFY_LOG_FILE:-$HOME/.codex/logs/codex-notify.log}"
CODEX_NOTIFY_TITLE="${CODEX_NOTIFY_TITLE:-Codex}"
CODEX_NOTIFY_TERMINAL_NOTIFIER="${CODEX_NOTIFY_TERMINAL_NOTIFIER:-}"
CODEX_NOTIFY_CLICK_HANDLER="${CODEX_NOTIFY_CLICK_HANDLER:-$script_dir/codex-focus-ghostty}"
CODEX_NOTIFY_GHOSTTY_BUNDLE_ID="${CODEX_NOTIFY_GHOSTTY_BUNDLE_ID:-com.mitchellh.ghostty}"
CODEX_NOTIFY_MESSAGE_MAX_CHARS="${CODEX_NOTIFY_MESSAGE_MAX_CHARS:-90}"
CODEX_NOTIFY_PYTHON_BIN="${CODEX_NOTIFY_PYTHON_BIN:-/usr/bin/python3}"

resolve_terminal_notifier() {
    local candidate=""

    for candidate in \
        "$CODEX_NOTIFY_TERMINAL_NOTIFIER" \
        /opt/homebrew/bin/terminal-notifier \
        /usr/local/bin/terminal-notifier \
        "$(command -v terminal-notifier 2>/dev/null || true)"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

resolve_codex_bin() {
    local candidate=""

    for candidate in \
        "$CODEX_BIN" \
        /opt/homebrew/bin/codex \
        /usr/local/bin/codex \
        "$(command -v codex 2>/dev/null || true)"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

escape_osascript_string() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

extract_json_field() {
    local key="$1"
    local payload="$2"

    printf '%s\n' "$payload" | sed -n "s/.*\"$key\":\"\\([^\"]*\\)\".*/\\1/p"
}

json_get_string() {
    local payload="$1"
    local key="$2"

    "$CODEX_NOTIFY_PYTHON_BIN" - "$payload" "$key" <<'PY'
import json
import sys

payload = sys.argv[1]
key = sys.argv[2]

try:
    value = json.loads(payload).get(key, "")
except Exception:
    value = ""

if isinstance(value, str):
    sys.stdout.write(value)
PY
}

json_find_string() {
    local payload="$1"
    shift

    "$CODEX_NOTIFY_PYTHON_BIN" - "$payload" "$@" <<'PY'
import json
import sys

payload = sys.argv[1]
keys = sys.argv[2:]

try:
    data = json.loads(payload)
except Exception:
    data = None

def walk(value):
    if isinstance(value, dict):
        for key in keys:
            item = value.get(key)
            if isinstance(item, str) and item.strip():
                sys.stdout.write(item)
                return True
        for item in value.values():
            if walk(item):
                return True
    elif isinstance(value, list):
        for item in value:
            if walk(item):
                return True
    return False

if data is not None:
    walk(data)
PY
}

notification_type_from_payload() {
    local payload="$1"
    local event_type=""

    event_type="$(json_get_string "$payload" "type")"
    if [ -z "$event_type" ]; then
        event_type="$(json_get_string "$payload" "method")"
    fi
    if [ -z "$event_type" ]; then
        event_type="$(json_get_string "$payload" "hook_event_name")"
    fi
    if [ -z "$event_type" ]; then
        case "$payload" in
            *'"type":"agent-turn-complete"'*)
                event_type="agent-turn-complete"
                ;;
            *'"type":"approval-requested"'*)
                event_type="approval-requested"
                ;;
            *'"type":"exec_approval_request"'*)
                event_type="exec_approval_request"
                ;;
            *'"type":"apply_patch_approval_request"'*)
                event_type="apply_patch_approval_request"
                ;;
            *'"type":"request_permissions"'*)
                event_type="request_permissions"
                ;;
            *'"method":"item/commandExecution/requestApproval"'*)
                event_type="item/commandExecution/requestApproval"
                ;;
            *'"method":"item/fileChange/requestApproval"'*)
                event_type="item/fileChange/requestApproval"
                ;;
            *'"method":"item/permissions/requestApproval"'*)
                event_type="item/permissions/requestApproval"
                ;;
            *'"hook_event_name":"PermissionRequest"'*)
                event_type="PermissionRequest"
                ;;
        esac
    fi

    printf '%s\n' "$event_type"
}

project_name_from_path() {
    local project_path="$1"

    if [ -z "$project_path" ] || [ "$project_path" = "/" ] || [ "$project_path" = "." ]; then
        return 0
    fi

    basename "$project_path"
}

project_path_from_payload() {
    local payload="$1"
    local project_path=""

    project_path="$(json_find_string "$payload" "cwd" "working_directory")"
    if [ -z "$project_path" ]; then
        project_path="$(extract_json_field "cwd" "$payload")"
    fi
    if [ -z "$project_path" ]; then
        project_path="$(extract_json_field "working_directory" "$payload")"
    fi

    printf '%s\n' "$project_path"
}

approval_detail_from_payload() {
    local payload="$1"

    "$CODEX_NOTIFY_PYTHON_BIN" - "$payload" <<'PY'
import json
import sys

payload = sys.argv[1]

try:
    data = json.loads(payload)
except Exception:
    data = None

def first_string(value, keys):
    if isinstance(value, dict):
        for key in keys:
            item = value.get(key)
            if isinstance(item, str) and item.strip():
                return item.strip()
        for item in value.values():
            found = first_string(item, keys)
            if found:
                return found
    elif isinstance(value, list):
        for item in value:
            found = first_string(item, keys)
            if found:
                return found
    return ""

if data is None:
    sys.exit(0)

parts = []

reason = first_string(data, ["reason", "message", "description", "prompt", "justification"])
if reason:
    parts.append(reason)

command = first_string(data, ["command", "program"])
if command:
    parts.append(f"Command: {command}")

host = first_string(data, ["host"])
protocol = first_string(data, ["protocol"])
port = first_string(data, ["port"])
if host:
    network = f"Network: {host}"
    if port:
        network += f":{port}"
    if protocol:
        network += f" ({protocol})"
    parts.append(network)

grant_root = first_string(data, ["grantRoot"])
if grant_root:
    parts.append(f"Path: {grant_root}")

tool_name = first_string(data, ["tool_name", "toolName", "tool_title", "toolTitle"])
if tool_name and not command:
    parts.append(f"Tool: {tool_name}")

deduped = []
seen = set()
for part in parts:
    normalized = part.strip()
    if not normalized:
        continue
    key = normalized.casefold()
    if key in seen:
        continue
    seen.add(key)
    deduped.append(normalized)

sys.stdout.write(" | ".join(deduped[:3]))
PY
}

log_notification() {
    local kind="$1"
    local message="$2"
    local log_message=""

    log_message="$(printf '%s' "$message" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"

    if [ -n "$CODEX_NOTIFY_LOG_FILE" ]; then
        mkdir -p "$(dirname "$CODEX_NOTIFY_LOG_FILE")" 2>/dev/null || true
        {
            printf '%s\t%s\t%s\n' "$kind" "$(date '+%Y-%m-%d %H:%M:%S')" "$log_message" >> "$CODEX_NOTIFY_LOG_FILE"
        } 2>/dev/null || true
    fi
}

play_sound() {
    local sound_path="$1"

    if [ -x /usr/bin/afplay ] && [ -r "$sound_path" ]; then
        /usr/bin/afplay "$sound_path" >/dev/null 2>&1 &
    fi
}

shell_single_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

build_click_command() {
    local project_path="$1"
    local helper="${CODEX_NOTIFY_CLICK_HANDLER:-}"
    local quoted_helper=""

    if [ -z "$helper" ] || [ ! -x "$helper" ]; then
        return 1
    fi

    quoted_helper="$(shell_single_quote "$helper")"
    if [ -n "$project_path" ]; then
        printf '%s %s\n' "$quoted_helper" "$(shell_single_quote "$project_path")"
        return 0
    fi

    printf '%s\n' "$quoted_helper"
}

show_popup_with_osascript() {
    local title="$1"
    local subtitle="$2"
    local message="$3"
    local escaped_title=""
    local escaped_subtitle=""
    local escaped_message=""

    if [ ! -x /usr/bin/osascript ]; then
        return 0
    fi

    escaped_title="$(escape_osascript_string "$title")"
    escaped_subtitle="$(escape_osascript_string "$subtitle")"
    escaped_message="$(escape_osascript_string "$message")"
    /usr/bin/osascript -e "display notification \"$escaped_message\" with title \"$escaped_title\" subtitle \"$escaped_subtitle\"" >/dev/null 2>&1 &
}

show_popup() {
    local title="$1"
    local subtitle="$2"
    local message="$3"
    local project_path="${4:-}"
    local click_command=""
    local terminal_notifier=""
    local -a notifier_args=()

    if [ "$CODEX_NOTIFY_POPUP" != "1" ]; then
        return 0
    fi

    click_command="$(build_click_command "$project_path" || true)"
    terminal_notifier="$(resolve_terminal_notifier || true)"
    if [ -n "$terminal_notifier" ]; then
        notifier_args=(
            -title "$title"
            -subtitle "$subtitle"
            -message "$message"
            -activate "$CODEX_NOTIFY_GHOSTTY_BUNDLE_ID"
        )
        if [ -n "$click_command" ]; then
            notifier_args+=(-execute "$click_command")
        fi
        "$terminal_notifier" "${notifier_args[@]}" >/dev/null 2>&1 || true
        return 0
    fi

    show_popup_with_osascript "$title" "$subtitle" "$message"
}

normalize_notification_text() {
    local text="$1"

    "$CODEX_NOTIFY_PYTHON_BIN" - "$text" <<'PY'
import re
import sys

text = sys.argv[1]

text = text.replace("\r", " ").replace("\n", " ")
text = re.sub(r"```.*?```", " ", text, flags=re.S)
text = re.sub(r"`([^`]*)`", r"\1", text)
text = re.sub(r"!\[([^\]]*)\]\([^)]+\)", r"\1", text)
text = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", text)
text = re.sub(r"^\s{0,3}#{1,6}\s*", "", text)
text = re.sub(r"[*_~]+", "", text)
text = re.sub(r"^\s{0,3}>\s*", "", text)
text = re.sub(r"\s+", " ", text).strip()

sys.stdout.write(text)
PY
}

first_line_notification_text() {
    local text="$1"

    "$CODEX_NOTIFY_PYTHON_BIN" - "$text" <<'PY'
import sys

text = sys.argv[1]
text = text.replace("\r\n", "\n").replace("\r", "\n")
sys.stdout.write(text.split("\n", 1)[0])
PY
}

truncate_notification_text() {
    local text="$1"
    local max_chars="${2:-$CODEX_NOTIFY_MESSAGE_MAX_CHARS}"

    "$CODEX_NOTIFY_PYTHON_BIN" - "$text" "$max_chars" <<'PY'
import sys

text = sys.argv[1].strip()
try:
    max_chars = int(sys.argv[2])
except Exception:
    max_chars = 90

if max_chars < 4 or len(text) <= max_chars:
    sys.stdout.write(text)
else:
    cut = text[: max_chars - 3]
    space = cut.rfind(" ")
    if space >= max(12, (max_chars - 3) // 2):
        cut = cut[:space]
    sys.stdout.write(cut.rstrip() + "...")
PY
}

status_line_for_project() {
    local project_path="$1"
    local status_suffix="$2"
    local project_name=""

    project_name="$(project_name_from_path "$project_path")"
    if [ -n "$project_name" ]; then
        printf '%s %s\n' "$project_name" "$status_suffix"
        return 0
    fi

    printf '%s\n' "$status_suffix"
}

notify_with_project() {
    local kind="$1"
    local sound_path="$2"
    local status_suffix="$3"
    local fallback_detail="$4"
    local project_path="${5:-}"
    local detail="${6:-}"
    local subtitle=""
    local message=""
    local log_message=""

    subtitle="$(status_line_for_project "$project_path" "$status_suffix")"
    case "$kind" in
        task_complete)
            detail="$(first_line_notification_text "$detail")"
            detail="$(normalize_notification_text "$detail")"
            if [ -z "$detail" ]; then
                detail="$fallback_detail"
            fi
            message="$(truncate_notification_text "$detail")"
            ;;
        *)
            detail="$(normalize_notification_text "$detail")"
            if [ -z "$detail" ]; then
                detail="$fallback_detail"
            fi
            message="$(truncate_notification_text "$detail")"
            ;;
    esac
    log_message="$subtitle"
    if [ -n "$message" ]; then
        log_message="$log_message | $message"
    fi

    log_notification "$kind" "$log_message"
    play_sound "$sound_path"
    show_popup "$CODEX_NOTIFY_TITLE" "$subtitle" "$message" "$project_path"
}

notify_task_complete() {
    notify_with_project "task_complete" "$CODEX_NOTIFY_SOUND" "finished" "Open Codex for details." "${1:-}" "${2:-}"
}

notify_approval_requested() {
    notify_with_project "approval_requested" "$CODEX_NOTIFY_APPROVAL_SOUND" "needs approval" "Review the pending approval in Codex." "${1:-}" "${2:-}"
}

handle_native_payload() {
    local payload="${1:-}"
    local event_type=""
    local project_path=""
    local detail=""

    event_type="$(notification_type_from_payload "$payload")"
    project_path="$(project_path_from_payload "$payload")"
    if [ -z "$project_path" ]; then
        project_path="${PWD:-}"
    fi

    case "$event_type" in
        agent-turn-complete)
            detail="$(json_get_string "$payload" "last-assistant-message")"
            notify_task_complete "$project_path" "$detail"
            ;;
        approval-requested|exec_approval_request|apply_patch_approval_request|request_permissions|item/commandExecution/requestApproval|item/fileChange/requestApproval|item/permissions/requestApproval|PermissionRequest)
            detail="$(approval_detail_from_payload "$payload")"
            notify_approval_requested "$project_path" "$detail"
            ;;
    esac
}

handle_permission_request_hook() {
    local payload=""

    payload="$(cat)"
    handle_native_payload "$payload"
}

handle_script_mode() {
    case "${1:-}" in
        --native-handler)
            shift
            handle_native_payload "${1:-}"
            return 0
            ;;
        --permission-request-hook)
            handle_permission_request_hook
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

main() {
    local codex_bin=""

    if handle_script_mode "$@"; then
        return 0
    fi

    codex_bin="$(resolve_codex_bin)" || {
        printf 'codex-notify: unable to locate codex binary\n' >&2
        return 1
    }
    exec "$codex_bin" "$@"
}

main "$@"
