#!/usr/bin/env bash

set -euo pipefail

script_dir="$(
    cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P
)"

# shellcheck source=/Users/posen/dotfiles/scripts/codex-notify-common
. "$script_dir/codex-notify-common"

payload="${1:-}"
project_path=""

project_path="$(project_path_from_payload "$payload")"
if [ -z "$project_path" ]; then
    project_path="${PWD:-}"
fi

case "$payload" in
    *'"type":"agent-turn-complete"'*)
        notify_task_complete "$project_path"
        ;;
esac
