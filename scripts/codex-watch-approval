#!/usr/bin/env python3

import json
import os
import signal
import subprocess
import sys
import time
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Dict
from typing import Iterable


SCRIPT_DIR = Path(__file__).resolve().parent
NOTIFY_COMMAND = Path(os.environ.get("CODEX_NOTIFY_COMMAND", str(SCRIPT_DIR / "codex-notify")))
SESSIONS_DIR = Path(os.environ.get("CODEX_NOTIFY_SESSIONS_DIR", str(Path.home() / ".codex" / "sessions")))
LSOF_BIN = os.environ.get("CODEX_NOTIFY_LSOF_BIN", "/usr/sbin/lsof")
DISCOVERY_TIMEOUT = int(os.environ.get("CODEX_NOTIFY_SESSION_DISCOVERY_TIMEOUT", "15"))
POLL_INTERVAL = float(os.environ.get("CODEX_NOTIFY_SESSION_POLL_INTERVAL", "0.5"))
PID_GRACE_SECONDS = float(os.environ.get("CODEX_NOTIFY_PID_GRACE_SECONDS", "2.0"))
PID_FILE_WAIT_SECONDS = float(os.environ.get("CODEX_NOTIFY_PID_FILE_WAIT_SECONDS", "2.0"))
TIMESTAMP_TOLERANCE_SECONDS = float(os.environ.get("CODEX_NOTIFY_TIMESTAMP_TOLERANCE_SECONDS", "2.0"))

STOP_REQUESTED = False


@dataclass
class SessionTracker:
    path: Path
    project_path: str
    offset: int = 0
    started_at: float | None = None
    cwd: str = ""


def handle_stop(_signum: int, _frame: object) -> None:
    global STOP_REQUESTED
    STOP_REQUESTED = True


def parse_timestamp(value: str | None) -> float | None:
    if not value:
        return None

    normalized = value
    if normalized.endswith("Z"):
        normalized = normalized[:-1] + "+00:00"

    try:
        return datetime.fromisoformat(normalized).timestamp()
    except ValueError:
        return None


def normalize_path(path: str) -> str:
    if not path:
        return ""

    expanded = os.path.expanduser(path)
    try:
        return str(Path(expanded).resolve())
    except OSError:
        return str(Path(expanded).absolute())


def read_pid(pid_file: Path | None) -> int | None:
    if pid_file is None or not pid_file.is_file():
        return None

    try:
        content = pid_file.read_text(encoding="utf-8").strip()
    except OSError:
        return None

    if not content.isdigit():
        return None

    return int(content)


def process_is_alive(pid: int | None) -> bool:
    if pid is None:
        return False

    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def list_session_paths_for_pid(pid: int | None) -> set[Path]:
    if pid is None or not LSOF_BIN:
        return set()

    try:
        result = subprocess.run(
            [LSOF_BIN, "-w", "-Fn", "-p", str(pid)],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError:
        return set()

    paths: set[Path] = set()
    sessions_root = str(SESSIONS_DIR.resolve())
    for line in result.stdout.splitlines():
        if not line.startswith("n"):
            continue

        path = Path(line[1:])
        if path.suffix != ".jsonl":
            continue

        try:
            resolved = path.resolve()
        except OSError:
            continue

        if not str(resolved).startswith(sessions_root + os.sep):
            continue

        paths.add(resolved)

    return paths


def iter_recent_session_files(marker_epoch: float) -> Iterable[Path]:
    if not SESSIONS_DIR.is_dir():
        return []

    cutoff = marker_epoch - TIMESTAMP_TOLERANCE_SECONDS
    paths: list[Path] = []
    for path in SESSIONS_DIR.rglob("*.jsonl"):
        try:
            if path.stat().st_mtime >= cutoff:
                paths.append(path.resolve())
        except OSError:
            continue

    return paths


def file_mtime(path: Path) -> float:
    try:
        return path.stat().st_mtime
    except OSError:
        return float("-inf")


def read_session_meta(path: Path) -> tuple[float | None, str]:
    try:
        with path.open("r", encoding="utf-8", errors="replace") as handle:
            first_line = handle.readline()
    except OSError:
        return None, ""

    if not first_line:
        return None, ""

    try:
        payload = json.loads(first_line)
    except json.JSONDecodeError:
        return None, ""

    if payload.get("type") != "session_meta":
        return None, ""

    session_payload = payload.get("payload")
    if not isinstance(session_payload, dict):
        return None, ""

    return parse_timestamp(session_payload.get("timestamp")), normalize_path(session_payload.get("cwd", ""))


def is_candidate_session(path: Path, requested_project_path: str, marker_epoch: float) -> tuple[bool, float | None, str]:
    started_at, cwd = read_session_meta(path)
    if not cwd or cwd != requested_project_path:
        return False, started_at, cwd

    if started_at is not None and started_at + TIMESTAMP_TOLERANCE_SECONDS < marker_epoch:
        return False, started_at, cwd

    return True, started_at, cwd


def line_timestamp(payload: dict) -> float | None:
    return parse_timestamp(payload.get("timestamp"))


def extract_approval_detail_key(payload: dict) -> str | None:
    body = payload.get("payload")
    if isinstance(body, dict):
        for key in ("approval_id", "call_id"):
            value = body.get(key)
            if isinstance(value, str) and value:
                return f"{payload.get('type')}:{value}"

    item = payload.get("payload")
    if isinstance(item, dict) and item.get("type") == "function_call":
        call_id = item.get("call_id")
        if isinstance(call_id, str) and call_id:
            return f"function_call:{call_id}"

    return None


def function_call_requires_approval(item: dict) -> bool:
    if item.get("type") != "function_call":
        return False

    arguments = item.get("arguments")
    if isinstance(arguments, str):
        try:
            parsed = json.loads(arguments)
        except json.JSONDecodeError:
            return '"sandbox_permissions"' in arguments and '"require_escalated"' in arguments

        return parsed.get("sandbox_permissions") == "require_escalated"

    if isinstance(arguments, dict):
        return arguments.get("sandbox_permissions") == "require_escalated"

    return False


def event_requires_approval(payload: dict) -> bool:
    item_type = payload.get("type")
    inner = payload.get("payload")

    if item_type == "event_msg" and isinstance(inner, dict):
        return inner.get("type") in {
            "exec_approval_request",
            "apply_patch_approval_request",
            "request_permissions",
        }

    if item_type == "response_item" and isinstance(inner, dict):
        return function_call_requires_approval(inner)

    return False


def notify(project_path: str, line: str) -> None:
    try:
        subprocess.run(
            [str(NOTIFY_COMMAND), "--approval-notify", project_path, line],
            check=False,
        )
    except OSError:
        return


def process_tracker(tracker: SessionTracker, marker_epoch: float, notified_keys: set[str]) -> None:
    try:
        current_size = tracker.path.stat().st_size
    except OSError:
        return

    if tracker.offset > current_size:
        tracker.offset = 0

    try:
        with tracker.path.open("r", encoding="utf-8", errors="replace") as handle:
            handle.seek(tracker.offset)
            while True:
                line = handle.readline()
                if not line:
                    break
                tracker.offset = handle.tell()
                stripped = line.strip()
                if not stripped:
                    continue

                try:
                    payload = json.loads(stripped)
                except json.JSONDecodeError:
                    continue

                event_ts = line_timestamp(payload)
                if event_ts is not None and event_ts + TIMESTAMP_TOLERANCE_SECONDS < marker_epoch:
                    continue

                if not event_requires_approval(payload):
                    continue

                key = extract_approval_detail_key(payload) or stripped
                if key in notified_keys:
                    continue

                notified_keys.add(key)
                notify(tracker.project_path, stripped)
    except OSError:
        return


def build_trackers(
    requested_project_path: str,
    marker_epoch: float,
    pid_candidates: Iterable[Path],
    fallback_candidates: Iterable[Path],
    trackers: Dict[Path, SessionTracker],
) -> set[Path]:
    preferred: list[tuple[Path, float | None, str]] = []
    for path in pid_candidates:
        matches, started_at, cwd = is_candidate_session(path, requested_project_path, marker_epoch)
        if not matches:
            continue
        preferred.append((path, started_at, cwd))

    if preferred:
        path, started_at, cwd = max(
            preferred,
            key=lambda candidate: (
                candidate[1] if candidate[1] is not None else float("-inf"),
                file_mtime(candidate[0]),
                str(candidate[0]),
            ),
        )
        tracker = trackers.setdefault(path, SessionTracker(path=path, project_path=cwd))
        tracker.project_path = cwd or requested_project_path
        tracker.started_at = started_at
        tracker.cwd = cwd
        return {path}

    fallback_matches: list[tuple[Path, float | None, str]] = []
    for path in fallback_candidates:
        matches, started_at, cwd = is_candidate_session(path, requested_project_path, marker_epoch)
        if not matches:
            continue
        fallback_matches.append((path, started_at, cwd))

    if not fallback_matches:
        return set()

    path, started_at, cwd = max(
        fallback_matches,
        key=lambda candidate: (
            candidate[1] if candidate[1] is not None else float("-inf"),
            file_mtime(candidate[0]),
            str(candidate[0]),
        ),
    )
    tracker = trackers.setdefault(path, SessionTracker(path=path, project_path=cwd))
    tracker.project_path = cwd or requested_project_path
    tracker.started_at = started_at
    tracker.cwd = cwd
    return {path}


def main() -> int:
    if len(sys.argv) < 4:
        return 2

    marker_file = Path(sys.argv[1])
    requested_project_path = normalize_path(sys.argv[3] or os.getcwd())
    pid_file = Path(sys.argv[4]) if len(sys.argv) > 4 and sys.argv[4] else None

    try:
        marker_epoch = marker_file.stat().st_mtime
    except OSError:
        marker_epoch = time.time()

    deadline = time.monotonic() + DISCOVERY_TIMEOUT
    trackers: Dict[Path, SessionTracker] = {}
    notified_keys: set[str] = set()
    child_pid: int | None = None
    child_exit_seen_at: float | None = None
    pid_wait_deadline = time.monotonic() + PID_FILE_WAIT_SECONDS if pid_file is not None else None

    signal.signal(signal.SIGTERM, handle_stop)
    signal.signal(signal.SIGINT, handle_stop)
    signal.signal(signal.SIGHUP, handle_stop)

    while not STOP_REQUESTED:
        current_pid = read_pid(pid_file) if child_pid is None else child_pid
        if current_pid is not None:
            child_pid = current_pid

        pid_alive = process_is_alive(child_pid)
        if child_pid is not None and not pid_alive:
            child_exit_seen_at = child_exit_seen_at or time.monotonic()
        elif pid_alive:
            child_exit_seen_at = None

        pid_candidates = list_session_paths_for_pid(child_pid) if pid_alive else set()
        fallback_candidates = []
        waiting_for_pid = (
            pid_file is not None
            and child_pid is None
            and pid_wait_deadline is not None
            and time.monotonic() < pid_wait_deadline
        )
        if not pid_candidates and not waiting_for_pid:
            fallback_candidates = list(iter_recent_session_files(marker_epoch))

        active_paths = build_trackers(
            requested_project_path=requested_project_path,
            marker_epoch=marker_epoch,
            pid_candidates=pid_candidates,
            fallback_candidates=fallback_candidates,
            trackers=trackers,
        )

        if active_paths or pid_candidates or fallback_candidates:
            for path in list(trackers):
                if path not in active_paths:
                    trackers.pop(path, None)

        for path in active_paths:
            process_tracker(trackers[path], marker_epoch, notified_keys)

        if child_exit_seen_at is not None and time.monotonic() - child_exit_seen_at >= PID_GRACE_SECONDS:
            break

        if child_pid is None and time.monotonic() >= deadline and not trackers:
            break

        time.sleep(POLL_INTERVAL)

    for tracker in list(trackers.values()):
        process_tracker(tracker, marker_epoch, notified_keys)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
