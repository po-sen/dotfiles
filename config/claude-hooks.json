{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${DOTFILES_ROOT}/scripts/claude-notify --session-start-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${DOTFILES_ROOT}/scripts/claude-notify --permission-request-hook",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${DOTFILES_ROOT}/scripts/claude-notify --stop-hook",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
