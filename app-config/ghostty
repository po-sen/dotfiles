# ===== font =====
font-family = ""
font-family = Menlo
font-family = PingFang TC
font-size = 15

# 避免缺少樣式時硬合成，減少 Codex TUI 字型怪掉的機率
font-synthetic-style = false

# macOS / Retina 觀感
font-thicken = true
font-thicken-strength = 35
alpha-blending = native
window-vsync = true
macos-window-shadow = false
macos-option-as-alt = left

# Run login bash so shell profile exports are available to Codex.
command = /opt/homebrew/bin/bash -l

# ===== colors =====
# Match the old iTerm2/xterm-style ANSI palette so git colors look familiar.
palette = 0=#000000
palette = 1=#c91b00
palette = 2=#00bb00
palette = 3=#bbbb00
palette = 4=#0000bb
palette = 5=#bb00bb
palette = 6=#00bbbb
palette = 7=#d8d8d8
palette = 8=#555555
palette = 9=#ff5555
palette = 10=#55ff55
palette = 11=#ffff55
palette = 12=#5555ff
palette = 13=#ff55ff
palette = 14=#55ffff
palette = 15=#ffffff
background = #000000
foreground = #D8D8D8
background-opacity = 1
selection-background = #B5D5FF
selection-foreground = #000000
window-theme = dark

# ===== spacing =====
# 拉開行距
adjust-cell-height = 8%

# 視窗邊界留白
window-padding-x = 8
window-padding-y = 2
# Ghostty 目前會把 balanced 後的垂直剩餘空間偏向放在底部，
# split pane 時看起來像某個 pane 下方多出空白行。
window-padding-balance = false
window-padding-color = background

# macOS only: 讓外層視窗 resize 時盡量貼齊 cell grid，減少底部 gap。
window-step-resize = true

# ===== cursor =====
cursor-style = bar
cursor-style-blink = true
cursor-color = #D8D8D8
adjust-cursor-thickness = 1
mouse-hide-while-typing = true

# ===== splits =====
# 不要讓沒 focus 的 pane 變灰
unfocused-split-opacity = 1
unfocused-split-fill = #000000

# 分隔線明顯一點
split-divider-color = #5A5A5A

# 新開 window/tab/split 跟著目前目錄走
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# 重開 Ghostty 時恢復上次的視窗狀態
window-save-state = always

# ===== notifications =====
shell-integration = detect
shell-integration-features = cursor,sudo,title,path,ssh-env

# ===== bell =====
bell-features = system,no-audio,no-attention,no-title,no-border

# ===== clear workaround =====
# Work around stale content after the first clear on macOS.
keybind = cmd+k=clear_screen
keybind = chain=clear_screen

# ===== terminal controls =====
# Avoid leaking Ghostty's modified-key escape sequence into shells that do not
# handle Shift+Enter specially.
keybind = shift+enter=text:\x0d
keybind = cmd+shift+j=write_screen_file:open,plain
keybind = cmd+alt+shift+j=write_screen_file:paste,plain
keybind = cmd+shift+r=toggle_readonly
keybind = cmd+shift+m=toggle_mouse_reporting

# ===== iTerm-like split behavior =====
split-preserve-zoom = navigation

# 右分割後自動 equalize
keybind = cmd+d=new_split:right
keybind = chain=equalize_splits

# 下分割後自動 equalize
keybind = shift+cmd+d=new_split:down
keybind = chain=equalize_splits
